# ═══════════════════════════════════════════════════════════════════════════
# KLO Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local for local dev, and set the same keys in
# Vercel → Project Settings → Environment Variables for production.
# .env.local is gitignored. NEVER commit a real .env file.
# ═══════════════════════════════════════════════════════════════════════════

# ── Firebase (web SDK) ─────────────────────────────────────────────────────
# From Firebase Console → Project Settings → Your apps → KLO Web → Config
# Project: klo-fullstack-66f70
VITE_FIREBASE_API_KEY=AIzaSyDVSndC4pI-W8z-2eCZkcCtrld79AwkUcM
VITE_FIREBASE_AUTH_DOMAIN=klo-fullstack-66f70.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=klo-fullstack-66f70
VITE_FIREBASE_STORAGE_BUCKET=klo-fullstack-66f70.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=97964985400
VITE_FIREBASE_APP_ID=1:97964985400:web:e1326e408d2102d6462acd
VITE_FIREBASE_MEASUREMENT_ID=G-N8BXY56CV2

# ── Supabase ───────────────────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role_key...
SUPABASE_ANON_KEY=eyJ...anon_key...

# v1.7.1+ : no VITE_SUPABASE_* needed. The browser fetches the anon key
# from GET /api/config on startup (server reads SUPABASE_URL +
# SUPABASE_ANON_KEY from its own env). This keeps the Vercel env-var
# config to one place (the server).

# ── AI Provider (server-side) ──────────────────────────────────────────────
# Options: gemini (default), claude, openrouter
AI_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Stripe (server-side) ──────────────────────────────────────────────────
# Test mode for now — switch to live keys when you onboard your first real supplier.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Telegram ──────────────────────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefghijk_lmnopqrstuvwxyz

# ── SendGrid (transactional email) ─────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx...
SENDGRID_FROM_EMAIL=hola@karibbeanluxuryoperators.lat
SENDGRID_FROM_NAME=KLO Operations

# ── Admin notification routing ─────────────────────────────────────────────
ADMIN_NOTIFICATION_EMAIL=hola@karibbeanluxuryoperators.lat

# ── Google Calendar (optional — suppliers can sync) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── WhatsApp (Maria FAB) ──────────────────────────────────────────────────
VITE_WHATSAPP_NUMBER=573243132500

# ── App URL ───────────────────────────────────────────────────────────────
# Auto-set by Vercel. Set manually for local dev.
# APP_URL is the SERVER-side origin. VITE_APP_URL is the BROWSER-side origin
# (exposed to the bundle via the VITE_ prefix). SupplierLogin uses
# VITE_APP_URL to build the magic-link redirectTo. In production both
# should be the real https://www.karibbeanluxuryoperators.lat so the
# email never points to localhost.
APP_URL=https://www.karibbeanluxuryoperators.lat
VITE_APP_URL=https://www.karibbeanluxuryoperators.lat
