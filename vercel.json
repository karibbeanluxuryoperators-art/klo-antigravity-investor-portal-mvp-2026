{
  "version": 2,
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node",
      "config": { "runtime": "nodejs22.x" }
    },
    { "src": "package.json", "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/dist/$1" }
  ]
}
